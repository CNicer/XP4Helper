{
  "name": "xp4helper",
  "displayName": "XP4Helper",
  "description": "Auto check file to p4",
  "version": "1.2.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "publisher": "yoloxu"
  },
  "publisher": "yoloxu",
  "icon": "resource/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "xp4helper.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "xp4helper.openfile",
        "title": "open file"
      },
      {
        "command": "xp4helper.refresh",
        "title": "refresh",
        "icon": {
          "light": "resource/dark_refresh.svg",
          "dark": "resource/white_refresh.png"
        }
      },
      {
        "command": "xp4helper.revert",
        "title": "Revert Change"
      },
      {
        "command": "xp4helper.checkout",
        "title": "P4: Checkout"
      },
      {
        "command": "xp4helper.revertFile",
        "title": "P4: Revert"
      },
      {
        "command": "xp4helper.diffHead",
        "title": "P4: Diff with Head"
      },
      {
        "command": "xp4helper.moveToChangelist",
        "title": "Move to Changelist..."
      },
      {
        "command": "xp4helper.newChangelist",
        "title": "New Changelist",
        "icon": "$(add)"
      },
      {
        "command": "xp4helper.fileHistory",
        "title": "P4: File History"
      },
      {
        "command": "xp4helper.submitChangelist",
        "title": "Submit Changelist"
      },
      {
        "command": "xp4helper.diffRevision",
        "title": "Diff Revisions"
      }
    ],
    "configuration": {
      "title": "XP4Helper",
      "properties": {
        "XP4Helper.P4PORT": {
          "type": "string",
          "description": "P4服务器地址xxx.xxx.xxx.xxx:1666"
        },
        "XP4Helper.P4USER": {
          "type": "string",
          "description": "P4用户名"
        },
        "XP4Helper.LogLevel": {
          "type": "string",
          "description": "插件日志Level",
          "default": "INFO"
        },
        "XP4Helper.ShowLineBlame": {
          "type": "boolean",
          "description": "在光标所在行末尾显示上一次提交人和日期(类似Git Blame)",
          "default": false
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "checkfiles",
          "title": "已Check文件",
          "icon": "resource/title.svg"
        }
      ]
    },
    "views": {
      "checkfiles": [
        {
          "id": "checkfiles",
          "name": "Checked Files"
        },
        {
          "id": "fileHistory",
          "name": "File History"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "xp4helper.refresh",
          "when": "view == checkfiles",
          "group": "navigation"
        },
        {
          "command": "xp4helper.newChangelist",
          "when": "view == checkfiles",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "xp4helper.revert",
          "when": "view == checkfiles && viewItem == filenode"
        },
        {
          "command": "xp4helper.moveToChangelist",
          "when": "view == checkfiles && viewItem == filenode"
        },
        {
          "command": "xp4helper.submitChangelist",
          "when": "view == checkfiles && viewItem == changelist"
        }
      ],
      "editor/context": [
        {
          "command": "xp4helper.checkout",
          "group": "p4@1"
        },
        {
          "command": "xp4helper.revertFile",
          "group": "p4@2"
        },
        {
          "command": "xp4helper.diffHead",
          "group": "p4@3"
        },
        {
          "command": "xp4helper.fileHistory",
          "group": "p4@4"
        }
      ],
      "explorer/context": [
        {
          "command": "xp4helper.checkout",
          "group": "p4@1"
        },
        {
          "command": "xp4helper.revertFile",
          "group": "p4@2"
        },
        {
          "command": "xp4helper.diffHead",
          "group": "p4@3"
        },
        {
          "command": "xp4helper.fileHistory",
          "group": "p4@4"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/sprintf-js": "^1.1.4",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0",
    "p4api": "^3.4.0",
    "p4js": "^1.1.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "iconv-lite": "^0.6.3",
    "sprintf-js": "^1.1.3"
  }
}
